# ============================================================
# RAG Chatbot - Environment Variables Template
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.
# ============================================================

# Application
ENVIRONMENT=development
DEBUG=true

# JWT Authentication
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Admin credentials (used for login authentication)
ADMIN_USER_ID=admin
ADMIN_PASSWORD=your-password-here

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# AWS Bedrock - Knowledge Base IDs
BEDROCK_KNOWLEDGE_BASE_ID=your-hr-knowledge-base-id
WORK_GUIDE_KNOWLEDGE_BASE_ID=your-work-guide-knowledge-base-id
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1

# RAG Settings
RAG_DISPLAY_THRESHOLD=0.4

# AWS CloudWatch Logging
CLOUDWATCH_LOG_GROUP=/aws/rag-chatbot
CLOUDWATCH_LOG_STREAM=chatbot-logs

# Session
SESSION_EXPIRE_MINUTES=60
MAX_CONVERSATION_TURNS=10

# CORS
FRONTEND_URL=http://localhost:3000

# PostgreSQL Database
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=postgres
PG_USER=your-db-user
PG_PASSWORD=your-db-password

# Glossary Settings
GLOSSARY_SEARCH_LIMIT=10
# GLOSSARY_MODEL_ID=   # Leave empty to use BEDROCK_MODEL_ID
